# ═══════════════════════════════════════════════════════
# NewsForge Backend — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Database (NeonDB PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ── JWT Secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
USER_JWT_SECRET=change-me-user-secret-key-64-chars-minimum
ADMIN_JWT_SECRET=change-me-admin-secret-key-64-chars-minimum

# ── Firebase (Google OAuth verification) ──
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: path to service account JSON file
# FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# ── Cloudflare R2 (S3-compatible object storage) ──
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=newsforge
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Groq API (AI Script Writer) ──
GROQ_API_KEY=gsk_your-groq-api-key

# ── CORS ──
CORS_ORIGINS=http://localhost:5500,http://localhost:3000,http://127.0.0.1:5500

# ── Admin IP Allowlist (comma-separated, empty = disabled) ──
ADMIN_IP_ALLOWLIST=

# ── App Config ──
APP_ENV=development
APP_VERSION=1.0.0
MIN_SUPPORTED_VERSION=1.0.0
